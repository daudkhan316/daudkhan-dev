---
const featuredProjects = [
  {
    title: 'Alpha Platform',
    blurb: 'A multi-platform social-publishing automation system that orchestrates content across Instagram, TikTok, LinkedIn, Pinterest, and YouTube. The writer, critic, and posting agents are built on Claude Code; a Spring Boot backend keeps the calendar honest, while an Angular dashboard surfaces planning and analytics. Currently powering my own social presence end-to-end.',
    stack: ['Spring Boot', 'Angular', 'TypeScript', 'Claude Code', 'PostgreSQL'],
    links: [],
  },
  {
    title: 'daudkhan.dev',
    blurb: 'This site. A static portfolio + writing platform built with Astro, Tailwind, and a small set of hand-rolled components. Deployed on Cloudflare Pages with auto-deploy from main, custom og:image generation, and dark-by-default styling inspired by Brittany Chiang’s v4 site.',
    stack: ['Astro', 'Tailwind CSS', 'Cloudflare Pages'],
    links: [
      { name: 'GitHub', href: 'https://github.com/daudkhan316/daudkhan-dev', icon: 'github' },
    ],
  },
];
---

<section
  id="projects"
  class="py-24 px-6 lg:px-12 max-w-6xl mx-auto scroll-mt-24"
>
  <h2 class="numbered-heading">Some Things I've Built</h2>

  <div class="space-y-24">
    {featuredProjects.map((p, i) => (
      <article class={`grid md:grid-cols-12 gap-4 md:gap-8 items-center ${i % 2 === 1 ? 'md:[&>div:first-child]:col-start-7' : ''}`}>
        <div class={`md:col-span-7 relative ${i % 2 === 1 ? 'md:order-1' : 'md:order-2'}`}>
          <div class="relative bg-light-navy rounded overflow-hidden border border-lightest-navy aspect-video flex items-center justify-center" style="border-radius: 4px;">
            <div class="absolute inset-0 bg-gradient-to-br from-green/10 to-transparent"></div>
            <span class="font-mono text-green text-2xl md:text-4xl font-bold tracking-tight px-8 text-center">
              {p.title}
            </span>
          </div>
        </div>

        <div class={`md:col-span-5 ${i % 2 === 1 ? 'md:order-2 md:text-left' : 'md:order-1 md:text-right'}`}>
          <p class="font-mono text-green text-xs mb-2">Featured Project</p>
          <h3 class="text-lightest-slate text-xl md:text-2xl font-semibold mb-4">
            {p.title}
          </h3>
          <div class="bg-light-navy text-light-slate p-5 rounded shadow-lg leading-relaxed text-sm" style="border-radius: 4px;">
            <p class="m-0">{p.blurb}</p>
          </div>
          <ul class={`flex flex-wrap gap-x-4 gap-y-1 mt-4 list-none p-0 font-mono text-xs text-light-slate ${i % 2 === 1 ? 'md:justify-start' : 'md:justify-end'}`}>
            {p.stack.map((s) => <li>{s}</li>)}
          </ul>
          {p.links.length > 0 && (
            <ul class={`flex gap-4 mt-4 list-none p-0 ${i % 2 === 1 ? 'md:justify-start' : 'md:justify-end'}`}>
              {p.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={link.name}
                    class="text-light-slate hover:text-green hover:-translate-y-0.5 inline-block transition-all duration-200"
                  >
                    {link.icon === 'github' && (
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
                    )}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </div>
      </article>
    ))}
  </div>
</section>
